# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Supabase (backend — Edge Functions) ─────────────────────────────────────
VITE_SUPABASE_URL="https://nxzvpcbudbqotujuuczo.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Set the same secrets in Supabase Dashboard → Edge Functions → Secrets:
# TURNSTILE_SECRET, PAYLOAD_ENCRYPTION_KEY, GATE_SESSION_SECRET, POW_SECRET

# ─── Frontend (Vite / Vercel) ────────────────────────────────────────────────
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
VITE_PAYLOAD_ENCRYPTION_KEY="use-a-long-random-secret-shared-with-supabase"

# Local dev
PORT=8787
NODE_ENV=development

# Optional: local Express fallback (npm run dev:express)
# VITE_API_PROXY_TARGET="http://localhost:8787"
