# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where the app is hosted in production.
APP_URL="http://localhost:8787"

# Express API server
PORT=8787
NODE_ENV=development

# Frontend (Vite) — create .env.local from these
VITE_API_BASE_URL=""
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
VITE_PAYLOAD_ENCRYPTION_KEY="use-a-long-random-secret-shared-with-server"

# Optional: override Vite dev proxy target (defaults to http://localhost:8787)
# VITE_API_PROXY_TARGET="http://localhost:8787"

# Server secrets — must match VITE_PAYLOAD_ENCRYPTION_KEY on the frontend
TURNSTILE_SECRET="your-turnstile-secret-key"
PAYLOAD_ENCRYPTION_KEY="use-a-long-random-secret-shared-with-frontend"
GATE_SESSION_SECRET="use-a-long-random-secret-for-signed-sessions"
POW_SECRET="use-a-long-random-secret-for-pow-challenges"
POW_DIFFICULTY="5"
POW_CHALLENGE_TTL_MS="60000"
