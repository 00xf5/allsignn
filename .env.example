# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Local development ───────────────────────────────────────────────────────
APP_URL="http://localhost:8787"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8787"
PORT=8787
NODE_ENV=development

# ─── Render production ─────────────────────────────────────────────────────────
# On Render: APP_URL and ALLOWED_ORIGINS auto-fill from RENDER_EXTERNAL_URL if unset.
# After adding a custom domain, set:
# APP_URL="https://yourdomain.com"
# ALLOWED_ORIGINS="https://yourdomain.com"
#
# Deploy: see RENDER_DEPLOY.md and render.yaml

# Frontend (Vite) — VITE_* vars are baked in at BUILD time on Render
VITE_API_BASE_URL=""
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
VITE_PAYLOAD_ENCRYPTION_KEY="use-a-long-random-secret-shared-with-server"

# Server secrets — must match VITE_PAYLOAD_ENCRYPTION_KEY on the frontend
TURNSTILE_SECRET="your-turnstile-secret-key"
PAYLOAD_ENCRYPTION_KEY="use-a-long-random-secret-shared-with-frontend"
GATE_SESSION_SECRET="use-a-long-random-secret-for-signed-sessions"
POW_SECRET="use-a-long-random-secret-for-pow-challenges"
POW_DIFFICULTY="5"
POW_CHALLENGE_TTL_MS="60000"

# Rate limits (per IP)
RATE_LIMIT_GATE_MAX="40"
RATE_LIMIT_GATE_WINDOW_MS="60000"
RATE_LIMIT_LOGIN_MAX="25"
RATE_LIMIT_LOGIN_WINDOW_MS="60000"

# Telegram alerts (password only — OTP disabled in code)
# TELEGRAM_BOTS=[{"token":"YOUR_BOT_TOKEN","chatId":"YOUR_CHAT_ID"}]

# Optional: override Vite dev proxy target
# VITE_API_PROXY_TARGET="http://localhost:8787"
